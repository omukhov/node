<%- include('partials/header') %>

<div class="container mt-4">
  <div class="row g-4">
    <% types.forEach(type => { %>
    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
      <div class="card h-100">
        <img
          src="<%= type.img %>"
          class="card-img-top"
          alt="<%= type.name %>"
        />

        <div class="card-body">
          <h5 class="card-title"><%= type.name %></h5>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
</div>

<%- include('partials/footer') %>
